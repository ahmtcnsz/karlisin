{
  "entities": {
    "WaitlistEntry": {
      "title": "Waitlist Entry",
      "description": "Represents a user who has joined the waitlist for a specific feature.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the user."
        },
        "source": {
          "type": "string",
          "description": "The feature the user is waiting for (e.g., 'temettu')."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user joined the waitlist."
        }
      },
      "required": ["email", "source", "createdAt"]
    },
    "NewsletterSubscriber": {
      "title": "Newsletter Subscriber",
      "description": "Represents a user who has subscribed to the newsletter.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email",
          "description": "The email address of the subscriber."
        },
        "source": {
          "type": "string",
          "description": "The source of the subscription (e.g., 'blog_newsletter')."
        },
        "subscribedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The timestamp when the user subscribed."
        }
      },
      "required": ["email", "source", "subscribedAt"]
    },
    "PortfolioAnalysis": {
      "title": "Portfolio Analysis",
      "description": "Represents an AI-generated analysis of a user's portfolio.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "portfolio": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "symbol": { "type": "string" },
              "amount": { "type": "number" },
              "cost": { "type": "number" }
            }
          }
        },
        "score": { "type": "number" },
        "distribution": { "type": "string" },
        "technicalNote": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "portfolio", "score", "distribution", "technicalNote", "createdAt"]
    },
    "UserStat": {
      "title": "User Statistics",
      "description": "Tracks usage limits and metadata for a user.",
      "type": "object",
      "properties": {
        "lastAnalysisAt": { "type": "string", "format": "date-time" },
        "analysesCount": { "type": "number" }
      }
    }
  },
  "firestore": {
    "/waitlist/{entryId}": {
      "schema": "WaitlistEntry",
      "description": "Collection of waitlist entries."
    },
    "/newsletter_subscribers/{entryId}": {
      "schema": "NewsletterSubscriber",
      "description": "Collection of newsletter subscribers."
    },
    "/portfolio_analyses/{analysisId}": {
      "schema": "PortfolioAnalysis",
      "description": "Historical portfolio analyses."
    },
    "/user_stats/{userId}": {
      "schema": "UserStat",
      "description": "User limits and stats."
    }
  }
}
