rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny Catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // 0.1 Global Helpers
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid)); }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // Pillar 2: Validation Blueprints
    function isValidWaitlistEntry(data) {
      return data.keys().hasAll(['email', 'source', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.email is string && data.email.size() <= 256 &&
             data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.source is string && data.source.size() <= 64 &&
             data.createdAt == request.time;
    }

    function isValidNewsletterEntry(data) {
      return data.keys().hasAll(['email', 'source', 'subscribedAt']) &&
             data.keys().size() == 3 &&
             data.email is string && data.email.size() <= 256 &&
             data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.source is string && data.source.size() <= 64 &&
             data.subscribedAt == request.time;
    }

    function isValidAnalysis(data) {
      return data.keys().hasAll(['userId', 'portfolio', 'score', 'distribution', 'technicalNote', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.userId == request.auth.uid &&
             data.portfolio is list && data.portfolio.size() <= 50 &&
             data.score is number &&
             data.distribution is string && data.distribution.size() <= 1000 &&
             data.technicalNote is string && data.technicalNote.size() <= 2000 &&
             data.createdAt == request.time;
    }

    function isValidContactRequest(data) {
      return data.keys().hasAll(['email', 'type', 'message', 'source', 'createdAt']) &&
             data.keys().size() == 5 &&
             data.email is string && data.email.size() <= 256 &&
             data.type is string && data.type.size() <= 64 &&
             data.message is string && data.message.size() <= 5000 &&
             data.source is string && data.source.size() <= 64 &&
             data.createdAt == request.time;
    }

    function isValidUserStat(data) {
       return data.keys().hasAll(['lastAnalysisAt', 'analysesCount']) &&
              data.keys().size() == 2 &&
              data.lastAnalysisAt == request.time &&
              data.analysesCount is number && data.analysesCount > 0;
    }

    // Match Blocks
    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false; // Only manageable through Firebase Console or Cloud Functions
    }

    match /waitlist/{entryId} {
      allow create: if isValidId(entryId) && isValidWaitlistEntry(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /newsletter_subscribers/{entryId} {
      allow create: if isValidId(entryId) && isValidNewsletterEntry(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /portfolio_analyses/{analysisId} {
      allow create: if isVerified() && isValidId(analysisId) && isValidAnalysis(incoming());
      allow get: if isVerified() && existing().userId == request.auth.uid;
      allow list: if isVerified() && resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /user_stats/{userId} {
      allow get: if isVerified() && request.auth.uid == userId;
      allow create: if isVerified() && request.auth.uid == userId && isValidUserStat(incoming()) && incoming().analysesCount == 1;
      allow update: if isVerified() && request.auth.uid == userId && isValidUserStat(incoming()) && 
                       incoming().analysesCount == existing().analysesCount + 1 &&
                       incoming().diff(existing()).affectedKeys().hasOnly(['lastAnalysisAt', 'analysesCount']);
      allow delete: if isAdmin();
    }

    match /contact_requests/{requestId} {
      allow create: if isValidId(requestId) && isValidContactRequest(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /system_config/{configId} {
      allow read, write: if isAdmin();
    }
  }
}
