rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helpers
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function isSignedIn() { return request.auth != null; }

    // Waitlist validation
    function isValidWaitlistEntry(data) {
      return data.keys().hasAll(['email', 'source', 'createdAt']) &&
             data.keys().size() == 3 &&
             data.email is string && data.email.size() <= 256 &&
             data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.source is string && data.source.size() <= 50 &&
             data.createdAt == request.time;
    }

    function isValidNewsletterEntry(data) {
      return data.keys().hasAll(['email', 'source', 'subscribedAt']) &&
             data.keys().size() == 3 &&
             data.email is string && data.email.size() <= 256 &&
             data.email.matches('^[^@]+@[^@]+\\.[^@]+$') &&
             data.source is string && data.source.size() <= 50 &&
             data.subscribedAt == request.time;
    }

    function isAdmin() { return isSignedIn() && request.auth.token.email == "admin@karlisin.com" && request.auth.token.email_verified == true; }

    function isValidAnalysis(data) {
      return data.userId == request.auth.uid &&
             data.portfolio is list &&
             data.score is number &&
             data.distribution is string &&
             data.technicalNote is string &&
             data.createdAt == request.time;
    }

    match /waitlist/{entryId} {
      allow create: if isValidWaitlistEntry(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /newsletter_subscribers/{entryId} {
      allow create: if isValidNewsletterEntry(incoming());
      allow list, get, update, delete: if isAdmin();
    }

    match /portfolio_analyses/{analysisId} {
      allow create: if isSignedIn() && isValidAnalysis(incoming());
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /user_stats/{userId} {
      allow get: if isSignedIn() && userId == request.auth.uid;
      allow create: if isSignedIn() && userId == request.auth.uid && 
                      incoming().analysesCount == 1 &&
                      incoming().lastAnalysisAt == request.time;
      allow update: if isSignedIn() && userId == request.auth.uid && 
                      incoming().analysesCount == resource.data.analysesCount + 1 &&
                      incoming().lastAnalysisAt == request.time;
    }
  }
}
